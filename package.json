    "@angular/platform-browser-dynamic": "21.2.1",
    "@angular/router": "21.2.1",
    "@convex-dev/auth": "0.0.91",
    "convex": "1.32.0",
    "jose": "6.2.0",
    "jwt-decode": "4.0.0",
    "lucia": "3.2.2",
    "preact": "10.28.4",
    "preact-render-to-string": "6.6.6",
